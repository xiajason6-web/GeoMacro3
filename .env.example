# Copy to .env and fill in. Loaded automatically by src/common.py.
# Needed only for the live LLM event coder (make code) — the Streamlit
# dashboard runs entirely on keyless sources.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: EIA weekly petroleum balances (free key: eia.gov/opendata).
# Activates the inventories driver in the fundamentals control.
EIA_API_KEY=
